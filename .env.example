# Network Configuration
# NETWORK can be: mainnet, testnet, previewnet, or custom
NETWORK=mainnet

# Custom Mirror Node URL (only used when NETWORK=custom)
# Leave empty for standard networks
CUSTOM_MIRROR_URL=

# Account Configuration
MY_ACCOUNT_ID=0.0.123456
MY_PRIVATE_KEY=302e020100300506032b657004220420...

# Transfer Limits
# MAX_TRANSFER: Maximum tokens per wallet (leave empty for no limit)
MAX_TRANSFER=

# Performance Settings
# MAX_CONCURRENT_TXS: Maximum concurrent transactions (default: 50)
MAX_CONCURRENT_TXS=50

# Transaction Settings
MEMO=Airdrop

# Exclusions
# EXCLUDE_WALLETS: Comma-separated list of wallet IDs to skip
EXCLUDE_WALLETS=

# EXCLUDE_SERIALS: For NFTs - specify serials to never send
# Format: comma-separated (1,2,3) OR range (1-100) - NEVER BOTH
EXCLUDE_SERIALS=